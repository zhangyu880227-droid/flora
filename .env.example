# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=flora
POSTGRES_PASSWORD=flora_dev_password
POSTGRES_DB=flora
DATABASE_URL=postgresql+asyncpg://flora:flora_dev_password@db:5432/flora

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-256-bit-hex-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AI Providers ──────────────────────────────────────────────────────────────
# LLM provider: "openai" (default) or "anthropic"
LLM_PROVIDER=openai

# OpenAI — default LLM provider (Responses API)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic — set LLM_PROVIDER=anthropic to use; install anthropic package first
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Voyage AI — embeddings (always required)
VOYAGE_API_KEY=pa-...

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=/data/uploads

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000"]
API_URL=http://localhost:8000

# ── Frontend (Next.js public) ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
